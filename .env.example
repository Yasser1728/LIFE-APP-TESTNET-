# Pi Network Integration Environment Variables
# Obtain these keys from your Pi Developer Portal (https://developers.minepi.com)

# --- Network-specific API keys ---
# Testnet app (App ID: life-app)
PI_API_KEY_TESTNET=your_testnet_pi_api_key_here

# Mainnet app (App ID: life-app-c468e9eb5bf115fa)
PI_API_KEY_MAINNET=your_mainnet_pi_api_key_here

# --- App Wallet (App-to-User payments) ---
# The BIP-39 seed phrase / passphrase for the app's Pi wallet.
# Keep this secret and NEVER commit it to source control.
PI_APP_WALLET_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
